 href=\"/\">\n                <div class=\"header-logo__text logo__text\">\n                    <div class=\"header-logo__title logo__title\">\n                        ShareCAD\n                    </div>\n                    <div class=\"header-logo__description logo__description\">\n                        Free online service to view<br>CAD files and 3D models\n                    </div>\n                </div>\n            </a>\n        </div>\n        <div class=\"header-info\">\n            <a href=\"mailto:info@cadsofttools.com\" class=\"header__mail header__link mail\">\n                <span class=\"mail__icon\">\n                    <svg>\n                        <use xlink:href=\"/Content/dialweb/img/svg-icons/sprite.svg#mail\"></use>\n                    </svg>\n                </span>\n                <span class=\"mail__text\">info@cadsofttools.com</span>\n            </a>\n            <div class=\"header-language\">\n\n                <a href=\"/en/Home/Index\" class=\"header-language__item header-language__item_active\">\n                    En\n                </a>\n\n                <a href=\"/de/Home/Index\" class=\"header-language__item \">\n                    De\n                </a>\n\n                <a href=\"/fr/Home/Index\" class=\"header-language__item \">\n                    Fr\n                </a>\n\n                <a href=\"/ru/Home/Index\" class=\"header-language__item \">\n                    Ru\n                </a>\n\n            </div>\n        </div>\n    </div>\n</div>\n</header>\n\n<main>\n\n    <section class=\"index-main\">\n        <div class=\"container\">\n            <div class=\"index-main__wrapper\">\n                <div class=\"index-main-convert\">\n                    <form action=\"/\" id=\"fileUpload\" method=\"post\" enctype=\"multipart/form-data\" class=\"index-main-form form-block\">\n                        <div class=\"index-main-form-drop-area drop-area\">\n                            <div class=\"index-main-form-drop-area__wrap drop-area__wrap\">\n                                <div class=\"index-main-form-error\">\n                                    <div class=\"index-main-form-error__close\"></div>\n                                    <div class=\"index-main-form-error__text\">\n                                        Error! The file format is not supported.\n                                    </div>\n                                    <div class=\"index-main-form-error__border\">\n\n                                    </div>\n                                </div>\n                                <div class=\"index-main-form__conv-icon\">\n                                    <img src=\"/Content/dialweb/img/base/refresh.png\" alt=\"\">\n                                </div>\n                                <div class=\"index-main-form__icon\">\n                                    <img src=\"/Content/dialweb/img/base/file.png\" alt=\"\">\n                                </div>\n                                <div class=\"index-main-form__description\">\n                                    Drag your file (up to 50 MB)\n                                    or\n                                </div>\n                                <label class=\"form-block__item form-block__item_add text-file internal-button button button_blue\">\n                                    <input type=\"file\" id=\"file\" name=\"file\" class=\"text-file-input visually-hidden\" value=\"\">\n                                    <span class=\"text-file__span\">\n                                        <span>SELECT FILE</span>\n                                    </span>\n                                </label>\n                                <div class=\"text-file__uploaded\">\n                                    <span class=\"text-file__name\"></span>\n                                </div>\n                                <progress class=\"progress-bar\" max=\"100\" value=\"50\"></progress>\n                            </div>\n                        </div>\n                    </form>\n                </div>\n                <div class=\"index-main-formats\">\n                    <div class=\"index-main-formats__title\">\n                        Supported formats:\n                    </div>\n                    <ul class=\"index-main-formats__items\">\n\n                        <li class=\"index-main-formats-item\">\n                            <span>\n                                CAD formats:\n                            </span>\n                            AutoCAD® DWG, DXF, DWF, HPGL, PLT\n                        </li>\n\n                        <li class=\"index-main-formats-item\">\n                            <span>\n                                Vector formats:\n                            </span>\n                            PDF, SVG, CGM, EMF, WMF\n                        </li>\n\n                        <li class=\"index-main-formats-item\">\n                            <span>\n                                3D formats:\n                            </span>\n                            STEP, STP, IGES, IGS, BREP, STL, SAT (ACIS), Parasolid® (X_T, X_B), SolidWorks® (SLDPRT)\n                        </li>\n\n                        <li class=\"index-main-formats-item\">\n                            <span>\n                                Raster formats:\n                            </span>\n                            PNG, BMP, JPG, GIF, TIFF, TGA, CAL\n                        </li>\n\n                        <li class=\"index-main-formats-item\">\n                            <span>\n                                Archives:\n                            </span>\n                            ZIP, 7ZIP, GZIP, RAR\n                        </li>\n\n                    </ul>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"index-advantages\">\n        <div class=\"container\">\n            <div class=\"index-advantages__wrapper\">\n                <div class=\"index-advantages__title title\">\n                    SHARECAD BENEFITS\n                </div>\n                <div class=\"index-advantages__items\">\n\n                    <div class=\"index-advantages-item\">\n                        <div class=\"index-advantages-item__icon\">\n                            <img src=\"/Content/dialweb/img/index/icon1.png\" alt=\"\">\n                        </div>\n                        <div class=\"index-advantages-item__description\">\n                            <div class=\"index-advantages-item__title\">\n                                SUPPORT OF A LARGE NUMBER OF CAD FORMATS\n                            </div>\n                            <div class=\"index-advantages-item__text\">\n                                Upload and view more than 25 commonly used 2D and 3D formats, including DWG, DXF, IGES, STEP, SLDPRT.\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"index-advantages-item\">\n                        <div class=\"index-advantages-item__icon\">\n                            <img src=\"/Content/dialweb/img/index/icon21.png\" alt=\"\">\n                        </div>\n                        <div class=\"index-advantages-item__description\">\n                            <div class=\"index-advantages-item__title\">\n                                COMPLETELY FREE SERVICE WITHOUT INSTALLATION\n                            </div>\n                            <div class=\"index-advantages-item__text\">\n                                No need to install anything and pay for subscriptions. All work is done on our servers at no cost.\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"index-advantages-item\">\n                        <div class=\"index-advantages-item__icon\">\n         